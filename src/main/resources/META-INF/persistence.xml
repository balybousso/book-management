<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="bookPU" transaction-type="RESOURCE_LOCAL">

        <class>sn.iage.isi.entities.Category</class>
        <class>sn.iage.isi.entities.Book</class>

        <properties>
            <!-- ===================== CONNEXION PostgreSQL ===================== -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/book_db"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="passer"/>

            <!-- ===================== HIBERNATE ===================== -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>

            <!-- create       : recrée le schéma à chaque démarrage   -->
            <!-- create-drop  : crée puis supprime à la fermeture      -->
            <!-- update       : met à jour le schéma sans perdre data  -->
            <!-- validate     : vérifie sans modifier                  -->
            <!-- none         : ne touche pas au schéma                -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Afficher les requêtes SQL dans la console -->
            <property name="hibernate.show_sql"   value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.use_sql_comments" value="true"/>

            <property name="hibernate.connection.pool_size" value="5"/>
        </properties>

    </persistence-unit>

</persistence>